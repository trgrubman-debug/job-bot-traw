# Copy this file to .env and fill in the values for the channels you want to use.
# .env is gitignored so your secrets stay local.

# ── Discord ─────────────────────────────────────────────────────────────────
# Get this URL from: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot with @BotFather to get the token.
# Get your chat ID by messaging your bot then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
